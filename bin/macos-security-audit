\`\`\`
Fix: System Settings > General > Sharing > Printer Sharing > Turn Off
\`\`\`"
        show_fix "Disable Printer Sharing" \
            "Open System Settings > General > Sharing > Printer Sharing > Turn Off"
        _record_medium_json "Printer Sharing is enabled" "Shared printers are accessible to other devices on your network."
    else
        pass "Printer Sharing is disabled"
    fi
}

check_sharing_media() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Media Sharing"

    local ms
    ms=$(defaults read com.apple.amp.mediasharingd home-sharing-enabled 2>/dev/null || echo "0")
    local ms2
    ms2=$(defaults read com.apple.amp.mediasharingd public-sharing-enabled 2>/dev/null || echo "0")

    if [[ "$ms" == "1" ]] || [[ "$ms2" == "1" ]]; then
        medium "Media Sharing is enabled" \
"Home Sharing or media library sharing exposes your media content on the local network.

\`\`\`
Fix: System Settings > General > Sharing > Media Sharing > Turn Off all toggles
\`\`\`"
        show_fix "Disable Media Sharing" \
            "Open System Settings > General > Sharing > Media Sharing > Turn Off"
        _record_medium_json "Media Sharing is enabled" "Home Sharing or media library sharing exposes your media content on the local network."
    else
        pass "Media Sharing is disabled"
    fi
}

check_sharing_handoff() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Handoff"

    local handoff_allowed="unknown"
    local byhost_dir="$HOME/Library/Preferences/ByHost"
    if [[ -d "$byhost_dir" ]]; then
        handoff_allowed=$(defaults read "$byhost_dir/com.apple.coreservices.useractivityd" ActivityAdvertisingAllowed 2>/dev/null || echo "unknown")
    fi

    if [[ "$handoff_allowed" == "0" ]]; then
        pass "Handoff is disabled"
    elif [[ "$handoff_allowed" == "1" ]]; then
        medium "Handoff is enabled" \
"Handoff shares activity data between your Apple devices via Bluetooth and Wi-Fi. On shared/public networks this can leak information about your activity.

\`\`\`
Fix: System Settings > General > AirDrop & Handoff > Allow Handoff between this Mac and your iCloud devices > Off
\`\`\`"
        show_fix "Disable Handoff" \
            "Open System Settings > General > AirDrop & Handoff > Handoff > Off"
        _record_medium_json "Handoff is enabled" "Handoff shares activity data between your Apple devices."
    else
        pass "Handoff: could not determine status"
    fi
}

###############################################################################
# CHECKS — Auth
###############################################################################

check_auth_users() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "User Accounts & Authentication"

    # Auto-login
    if defaults read /Library/Preferences/com.apple.loginwindow autoLoginUser &>/dev/null; then
        critical "Auto-login is ENABLED" \
"Anyone who opens the laptop lid gets full access — no password required.

\`\`\`
Fix: System Settings > Users & Groups > Disable automatic login
\`\`\`"
        show_fix "Disable auto-login" \
            "sudo defaults delete /Library/Preferences/com.apple.loginwindow autoLoginUser"
        _record_critical_json "Auto-login is ENABLED" "Anyone who opens the laptop lid gets full access."
    else
        pass "Auto-login is disabled"
    fi

    # Admin users
    ADMIN_USERS=$(dscl . -read /Groups/admin GroupMembership 2>/dev/null | sed 's/GroupMembership: //' || echo "")
    ADMIN_COUNT=$(echo "$ADMIN_USERS" | wc -w | tr -d ' ')
    if (( ADMIN_COUNT > 2 )); then
        medium "Multiple admin accounts: $ADMIN_USERS" \
"More admin accounts = larger attack surface. Use a standard account for daily use.

\`\`\`
Fix: System Settings > Users & Groups > demote unnecessary admins to Standard
\`\`\`"
        show_fix "Demote unnecessary admin accounts" \
            "# System Settings > Users & Groups > select user > change to Standard"
        _record_medium_json "Multiple admin accounts: $ADMIN_USERS" "More admin accounts = larger attack surface."
    else
        pass "Admin users: $ADMIN_USERS"
    fi

    # Screen lock / password after sleep
    SCREENLOCK_STATUS=$(sysadminctl -screenLock status 2>&1 || true)
    if echo "$SCREENLOCK_STATUS" | grep -qi "immediate"; then
        pass "Screen lock requires password immediately"
    elif echo "$SCREENLOCK_STATUS" | grep -qi "screenLock delay"; then
        DELAY_INFO=$(echo "$SCREENLOCK_STATUS" | sed 's/.*screenLock delay is //')
        medium "Screen lock delay is: ${DELAY_INFO}" \
"An attacker with brief physical access could unlock the machine within the grace window.

\`\`\`
Fix: System Settings > Lock Screen > Require password after screen saver begins
     or display is turned off: 'Immediately'
\`\`\`"
        show_fix "Set screen lock to immediate" \
            "sysadminctl -screenLock immediate -password -"
        _record_medium_json "Screen lock delay is: ${DELAY_INFO}" "An attacker with brief physical access could unlock the machine."
    else
        ASK_PWD=$(defaults read com.apple.screensaver askForPassword 2>/dev/null || echo "unknown")
        ASK_DELAY=$(defaults read com.apple.screensaver askForPasswordDelay 2>/dev/null || echo "unknown")
        if [[ "$ASK_PWD" == "1" && "$ASK_DELAY" == "0" ]]; then
            pass "Screen lock requires password immediately"
        elif [[ "$ASK_PWD" == "1" ]]; then
            medium "Screen lock has a grace period of ${ASK_DELAY}s before requiring password" \
"An attacker with brief physical access could unlock the machine within the grace window.

\`\`\`
Fix: System Settings > Lock Screen > Require password: 'Immediately'
\`\`\`"
            show_fix "Set screen lock to immediate" \
                "defaults write com.apple.screensaver askForPasswordDelay -int 0"
            _record_medium_json "Screen lock has a grace period of ${ASK_DELAY}s" "An attacker with brief physical access could unlock the machine."
        else
            medium "Could not confirm screen lock requires password immediately" \
"Verify manually that password is required immediately on sleep/screensaver.

\`\`\`
Fix: System Settings > Lock Screen > Require password: 'Immediately'
\`\`\`"
            _record_medium_json "Could not confirm screen lock requires password immediately" "Verify manually."
        fi
    fi

    # Keychain lock timeout
    KC_INFO=$(security show-keychain-info ~/Library/Keychains/login.keychain-db 2>&1 || true)
    if echo "$KC_INFO" | grep -q "no-timeout"; then
        high "Login keychain has no lock timeout" \
"Once unlocked at login, your keychain stays unlocked forever. Malware with code execution can extract all stored secrets without re-prompting.

\`\`\`
Fix: security set-keychain-settings -t 3600 -l ~/Library/Keychains/login.keychain-db
     (locks after 1 hour of inactivity and on sleep)
\`\`\`"
        show_fix "Set keychain to lock after 1 hour and on sleep" \
            "security set-keychain-settings -t 3600 -l ~/Library/Keychains/login.keychain-db"
        _record_high_json "Login keychain has no lock timeout" "Once unlocked at login, your keychain stays unlocked forever."
    else
        pass "Login keychain has a lock timeout configured"
    fi
}

check_auth_ssh() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "SSH Configuration"

    AUTH_KEYS="$HOME/.ssh/authorized_keys"
    if [[ -f "$AUTH_KEYS" ]] && [[ -s "$AUTH_KEYS" ]]; then
        KEY_COUNT=$(wc -l < "$AUTH_KEYS" | tr -d ' ')
        high "$KEY_COUNT key(s) in authorized_keys — verify they are all yours" \
"Any key listed here grants passwordless SSH access to this machine.

\`\`\`
Fix: Review ~/.ssh/authorized_keys and remove any unrecognised keys
\`\`\`"
        show_fix "Review authorized_keys" \
            "cat ~/.ssh/authorized_keys" \
            "# Remove unrecognised keys with a text editor"
        _record_high_json "$KEY_COUNT key(s) in authorized_keys" "Any key listed here grants passwordless SSH access to this machine."
    else
        pass "No authorized_keys file (or empty)"
    fi

    SSH_DIR_PERMS=$(stat -f "%Lp" ~/.ssh 2>/dev/null || echo "")
    if [[ -n "$SSH_DIR_PERMS" && "$SSH_DIR_PERMS" != "700" ]]; then
        medium "~/.ssh directory permissions are $SSH_DIR_PERMS (should be 700)" \
"\`\`\`
Fix: chmod 700 ~/.ssh
\`\`\`"
        show_fix "Fix ~/.ssh permissions" \
            "chmod 700 ~/.ssh"
        _record_medium_json "~/.ssh directory permissions are $SSH_DIR_PERMS (should be 700)" "Fix permissions to 700."
    elif [[ -n "$SSH_DIR_PERMS" ]]; then
        pass "~/.ssh permissions are 700"
    fi
}

check_auth_screensaver() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Screen Saver Timeout"

    local idle_time
    idle_time=$(defaults read com.apple.screensaver idleTime 2>/dev/null || echo "0")

    if [[ "$idle_time" == "0" ]] || [[ -z "$idle_time" ]]; then
        medium "Screen saver is not configured to activate automatically" \
"Without an automatic screen saver, your screen stays unlocked indefinitely when you walk away.

\`\`\`
Fix: System Settings > Lock Screen > 'Start Screen Saver when inactive' > set to 5 minutes or less
\`\`\`"
        show_fix "Set screen saver timeout" \
            "defaults write com.apple.screensaver idleTime -int 300"
        _record_medium_json "Screen saver is not configured to activate automatically" "Your screen stays unlocked indefinitely when you walk away."
    elif (( idle_time > 600 )); then
        medium "Screen saver timeout is ${idle_time}s (more than 10 minutes)" \
"A long timeout leaves your machine accessible if you step away.

\`\`\`
Fix: System Settings > Lock Screen > 'Start Screen Saver when inactive' > 5 minutes or less
\`\`\`"
        show_fix "Reduce screen saver timeout to 5 minutes" \
            "defaults write com.apple.screensaver idleTime -int 300"
        _record_medium_json "Screen saver timeout is ${idle_time}s (more than 10 minutes)" "A long timeout leaves your machine accessible."
    else
        pass "Screen saver activates after ${idle_time}s"
    fi
}

check_auth_login_window() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Login Window Configuration"

    local issues=""

    local show_full
    show_full=$(defaults read /Library/Preferences/com.apple.loginwindow SHOWFULLNAME 2>/dev/null || echo "unknown")
    if [[ "$show_full" == "0" ]]; then
        issues="${issues}  - Login window shows user list (reveals account names)\n"
    fi

    local hints
    hints=$(defaults read /Library/Preferences/com.apple.loginwindow RetriesUntilHint 2>/dev/null || echo "unknown")
    if [[ "$hints" != "0" ]] && [[ "$hints" != "unknown" ]]; then
        issues="${issues}  - Password hints shown after ${hints} failed attempt(s)\n"
    fi

    if [[ -n "$issues" ]]; then
        medium "Login window configuration could be hardened" \
"$(echo -e "$issues")
\`\`\`
Fix: defaults write /Library/Preferences/com.apple.loginwindow SHOWFULLNAME -bool true
     defaults write /Library/Preferences/com.apple.loginwindow RetriesUntilHint -int 0
\`\`\`"
        show_fix "Harden login window" \
            "sudo defaults write /Library/Preferences/com.apple.loginwindow SHOWFULLNAME -bool true" \
            "sudo defaults write /Library/Preferences/com.apple.loginwindow RetriesUntilHint -int 0"
        _record_medium_json "Login window configuration could be hardened" "Login window reveals account names or password hints."
    else
        pass "Login window configuration is hardened"
    fi
}

check_auth_touchid() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Touch ID"

    TOUCHID_HW=$(biometric -s 2>/dev/null || system_profiler SPiBridgeDataType 2>/dev/null | grep -i "fingerprint" || echo "")
    TOUCHID_ENROLLED=$(bioutil -c -s 2>/dev/null || echo "")

    if echo "$TOUCHID_ENROLLED" | grep -qi "fingerprints.*:.*[1-9]"; then
        pass "Touch ID is enrolled with fingerprint(s)"
    elif echo "$TOUCHID_ENROLLED" | grep -qi "fingerprints.*:.*0\|no fingerprints\|not enrolled"; then
        medium "Touch ID hardware present but no fingerprints enrolled" \
"Touch ID adds a strong physical access control layer. Without it, only a password protects your session.

\`\`\`
Fix: System Settings > Touch ID & Password > Add a Fingerprint
\`\`\`"
        show_fix "Enroll a fingerprint in Touch ID" \
            "Open System Settings > Touch ID & Password > Add a Fingerprint"
        _record_medium_json "Touch ID hardware present but no fingerprints enrolled" "Touch ID adds a strong physical access control layer."
    elif [[ -n "$TOUCHID_HW" ]]; then
        BIOUTIL_OUTPUT=$(bioutil -rs 2>/dev/null || echo "")
        if echo "$BIOUTIL_OUTPUT" | grep -qi "count.*[1-9]\|user.*template"; then
            pass "Touch ID is enrolled"
        else
            medium "Touch ID may not be enrolled — verify manually" \
"Could not confirm fingerprint enrollment. Touch ID adds a strong physical access control layer.

\`\`\`
Fix: System Settings > Touch ID & Password > Add a Fingerprint
\`\`\`"
            show_fix "Enroll a fingerprint in Touch ID" \
                "Open System Settings > Touch ID & Password > Add a Fingerprint"
            _record_medium_json "Touch ID may not be enrolled" "Could not confirm fingerprint enrollment."
        fi
    else
        pass "Touch ID: not available on this hardware (skipped)"
    fi
}

check_auth_usb() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "USB Restricted Mode"

    ACCESSORY_SECURITY=$(defaults read /Library/Preferences/com.apple.security USBRestrictedMode 2>/dev/null || echo "unknown")

    if [[ "$ACCESSORY_SECURITY" == "0" ]]; then
        high "USB Restricted Mode is DISABLED" \
"USB accessories can connect even when your Mac is locked. This allows USB-based attacks (BadUSB, rubber ducky) without requiring unlock.

\`\`\`
Fix: System Settings > Privacy & Security > Allow accessories to connect > 'Ask for New Accessories'
\`\`\`"
        show_fix "Enable USB Restricted Mode" \
            "Open System Settings > Privacy & Security > Allow accessories to connect > 'Ask for New Accessories'"
        _record_high_json "USB Restricted Mode is DISABLED" "USB accessories can connect even when your Mac is locked."
    else
        pass "USB Restricted Mode: accessories require approval or device is unlocked"
    fi
}

###############################################################################
# CHECKS — Privacy
###############################################################################

check_privacy_location() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Location Services"

    LOCATION_ENABLED="unknown"
    LOCATION_ENABLED=$(sudo -n defaults read /var/db/locationd/Library/Preferences/ByHost/com.apple.locationd LocationServicesEnabled 2>/dev/null || echo "unknown")
    if [[ "$LOCATION_ENABLED" == "unknown" ]]; then
        LOCATION_ENABLED=$(defaults read /var/db/locationd/Library/Preferences/ByHost/com.apple.locationd LocationServicesEnabled 2>/dev/null || echo "unknown")
    fi
    if [[ "$LOCATION_ENABLED" == "unknown" ]]; then
        if launchctl list com.apple.locationd &>/dev/null; then
            LOCATION_ENABLED="1"
        else
            LOCATION_ENABLED="0"
        fi
    fi

    if [[ "$LOCATION_ENABLED" == "1" ]]; then
        medium "Location Services are enabled globally" \
"Location Services allow apps to access your physical location. Review which apps have access.

\`\`\`
Fix: System Settings > Privacy & Security > Location Services > review app access
     Disable entirely if not needed: toggle off Location Services
\`\`\`"
        show_fix "Review Location Services settings" \
            "Open System Settings > Privacy & Security > Location Services"
        _record_medium_json "Location Services are enabled globally" "Location Services allow apps to access your physical location."
    elif [[ "$LOCATION_ENABLED" == "0" ]]; then
        pass "Location Services are disabled"
    else
        pass "Location Services: could not determine status (check manually)"
    fi
}

check_privacy_analytics() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Analytics & Telemetry Sharing"

    ANALYTICS_ISSUES=""

    SHARE_ANALYTICS=$(defaults read /Library/Application\ Support/CrashReporter/DiagnosticMessagesHistory.plist AutoSubmit 2>/dev/null || echo "unknown")
    if [[ "$SHARE_ANALYTICS" == "1" ]]; then
        ANALYTICS_ISSUES="${ANALYTICS_ISSUES}  - Apple Analytics (Share Mac Analytics) is ON\n"
    fi

    SHARE_APP_DEV=$(defaults read /Library/Application\ Support/CrashReporter/DiagnosticMessagesHistory.plist ThirdPartyDataSubmit 2>/dev/null || echo "unknown")
    if [[ "$SHARE_APP_DEV" == "1" ]]; then
        ANALYTICS_ISSUES="${ANALYTICS_ISSUES}  - Share with App Developers is ON\n"
    fi

    SIRI_DATA=$(defaults read com.apple.assistant.support "Siri Data Sharing Opt-In Status" 2>/dev/null || echo "unknown")
    if [[ "$SIRI_DATA" == "2" ]]; then
        ANALYTICS_ISSUES="${ANALYTICS_ISSUES}  - Improve Siri & Dictation is ON\n"
    fi

    if [[ -n "$ANALYTICS_ISSUES" ]]; then
        medium "Analytics & telemetry sharing is enabled" \
"The following telemetry sharing options are active:

$(echo -e "$ANALYTICS_ISSUES")
Data is sent to Apple (and potentially third-party developers), which may include usage patterns and diagnostic information.

\`\`\`
Fix: System Settings > Privacy & Security > Analytics & Improvements > disable all toggles
\`\`\`"
        show_fix "Disable analytics sharing" \
            "defaults write '/Library/Application Support/CrashReporter/DiagnosticMessagesHistory.plist' AutoSubmit -bool false" \
            "defaults write '/Library/Application Support/CrashReporter/DiagnosticMessagesHistory.plist' ThirdPartyDataSubmit -bool false" \
            "defaults write com.apple.assistant.support 'Siri Data Sharing Opt-In Status' -int 0"
        _record_medium_json "Analytics & telemetry sharing is enabled" "Telemetry sharing options are active."
    else
        pass "Analytics & telemetry sharing appears disabled"
    fi
}

check_privacy_bluetooth() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Bluetooth Discoverability"

    BT_INFO=$(system_profiler SPBluetoothDataType 2>/dev/null || true)
    BT_POWER="unknown"
    if echo "$BT_INFO" | grep -qi "State:.*On\|Power:.*On\|Bluetooth.*On"; then
        BT_POWER="1"
    elif echo "$BT_INFO" | grep -qi "State:.*Off\|Power:.*Off\|Bluetooth.*Off"; then
        BT_POWER="0"
    else
        BT_POWER=$(defaults read /Library/Preferences/com.apple.Bluetooth ControllerPowerState 2>/dev/null || echo "unknown")
    fi

    if [[ "$BT_POWER" == "0" ]]; then
        pass "Bluetooth is OFF"
    elif [[ "$BT_POWER" == "1" ]]; then
        BT_DISC_STATUS=$(echo "$BT_INFO" | awk -F': ' '/Discoverable/{print $2; exit}' || echo "unknown")
        if [[ "$BT_DISC_STATUS" == *"Yes"* ]]; then
            high "Bluetooth is ON and discoverable" \
"Your Mac is visible to all nearby Bluetooth devices, which can be used for tracking and proximity attacks.

\`\`\`
Fix: System Settings > Bluetooth > Turn off when not in use
     Or close the Bluetooth settings pane to stop discoverability
\`\`\`"
            show_fix "Turn off Bluetooth (if not needed)" \
                "sudo defaults write /Library/Preferences/com.apple.Bluetooth ControllerPowerState -int 0" \
                "sudo killall -HUP bluetoothd"
            _record_high_json "Bluetooth is ON and discoverable" "Your Mac is visible to all nearby Bluetooth devices."
        else
            pass "Bluetooth is ON but not discoverable"
        fi
    else
        if pgrep -q bluetoothd 2>/dev/null; then
            pass "Bluetooth daemon is running (state unclear — verify in System Settings)"
        else
            pass "Bluetooth appears OFF (daemon not running)"
        fi
    fi
}

check_privacy_siri() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Siri Voice Trigger"

    local siri_voice
    siri_voice=$(defaults read com.apple.Siri VoiceTriggerUserEnabled 2>/dev/null || echo "unknown")
    if [[ "$siri_voice" == "1" ]]; then
        medium "'Hey Siri' voice trigger is enabled" \
"Always-on microphone listening is a privacy concern.

\`\`\`
Fix: System Settings > Siri & Spotlight > Disable 'Listen for \"Hey Siri\"'
\`\`\`"
        show_fix "Disable Hey Siri voice trigger" \
            "defaults write com.apple.Siri VoiceTriggerUserEnabled -bool false"
        _record_medium_json "'Hey Siri' voice trigger is enabled" "Always-on microphone listening is a privacy concern."
    elif [[ "$siri_voice" == "0" ]]; then
        pass "'Hey Siri' voice trigger is disabled"
    else
        pass "Siri voice trigger: could not determine status"
    fi
}

###############################################################################
# CHECKS — Software
###############################################################################

check_software_updates() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Software Updates"

    AUTO_CHECK=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate AutomaticCheckEnabled 2>/dev/null || echo "missing")
    AUTO_DL=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate AutomaticDownload 2>/dev/null || echo "0")
    CRITICAL_INSTALL=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate CriticalUpdateInstall 2>/dev/null || echo "0")
    AUTO_MACOS=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate AutomaticallyInstallMacOSUpdates 2>/dev/null || echo "0")

    UPDATES_OK=true
    if [[ "$AUTO_CHECK" == "0" ]]; then UPDATES_OK=false; fi
    if [[ "$AUTO_DL" == "0" ]]; then UPDATES_OK=false; fi
    if [[ "$CRITICAL_INSTALL" == "0" ]]; then UPDATES_OK=false; fi
    if [[ "$AUTO_MACOS" == "0" ]]; then UPDATES_OK=false; fi

    if $UPDATES_OK; then
        pass "Automatic security updates enabled"
    else
        high "Automatic security updates not fully enabled" \
"Critical patches may not be installed automatically, leaving known vulnerabilities open.

\`\`\`
Fix: System Settings > General > Software Update > Automatic Updates > enable all toggles
\`\`\`"
        show_fix "Enable automatic updates" \
            "sudo defaults write /Library/Preferences/com.apple.SoftwareUpdate AutomaticCheckEnabled -bool true" \
            "sudo defaults write /Library/Preferences/com.apple.SoftwareUpdate AutomaticDownload -bool true" \
            "sudo defaults write /Library/Preferences/com.apple.SoftwareUpdate CriticalUpdateInstall -bool true" \
            "sudo defaults write /Library/Preferences/com.apple.SoftwareUpdate AutomaticallyInstallMacOSUpdates -bool true"
        _record_high_json "Automatic security updates not fully enabled" "Critical patches may not be installed automatically."
    fi

    PENDING=$(softwareupdate -l 2>&1)
    if echo "$PENDING" | grep -q "No new software available"; then
        pass "macOS is up to date"
    else
        high "Pending software updates available" \
"$PENDING

\`\`\`
Fix: softwareupdate --install --all
\`\`\`"
        show_fix "Install pending updates" \
            "sudo softwareupdate --install --all"
        _record_high_json "Pending software updates available" "Updates are available for installation."
    fi
}

check_software_review() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Installed Software & Persistence"

    # ── Offensive / dual-use tools ──
    OFFENSIVE_TOOLS=""
    for tool in bettercap mitmproxy nmap wireshark sherlock hydra john hashcat metasploit msfconsole aircrack-ng; do
        if cmd_exists "$tool"; then
            OFFENSIVE_TOOLS="${OFFENSIVE_TOOLS}  - ${tool}\n"
        fi
    done
    for app in Wireshark Burp\ Suite; do
        if [[ -d "/Applications/${app}.app" ]]; then
            OFFENSIVE_TOOLS="${OFFENSIVE_TOOLS}  - ${app} (GUI)\n"
        fi
    done

    if [[ -n "$OFFENSIVE_TOOLS" ]]; then
        medium "Offensive / dual-use security tools installed" \
"While legitimate for security work, these increase attack surface and could be weaponised if your machine is compromised:

$(echo -e "$OFFENSIVE_TOOLS")
\`\`\`
Fix: Uninstall any you're not actively using. Keep them in a VM if needed for security work.
\`\`\`"
        qecho -e "$OFFENSIVE_TOOLS"
        show_fix "Uninstall unused offensive tools (example)" \
            "brew uninstall nmap" \
            "# Or remove from /Applications"
        _record_medium_json "Offensive / dual-use security tools installed" "These tools increase attack surface."
    else
        pass "No offensive tools detected"
    fi

    # ── Third-party LaunchDaemons ──
    THIRD_PARTY_DAEMONS=$(ls /Library/LaunchDaemons/ 2>/dev/null | grep -v '^com.apple' || true)
    if [[ -n "$THIRD_PARTY_DAEMONS" ]]; then
        DAEMON_LIST=$(echo "$THIRD_PARTY_DAEMONS" | sed 's/^/  - /')

        if echo "$THIRD_PARTY_DAEMONS" | grep -qi "teamviewer"; then
            critical "TeamViewer LaunchDaemons are installed" \
"TeamViewer has persistent system-level daemons running as root. TeamViewer has been repeatedly compromised (2016, 2019, 2024 breaches) and is a known target for intelligence services.

Third-party LaunchDaemons found:
$DAEMON_LIST

**How to fully uninstall TeamViewer:**

1. Quit TeamViewer if running
2. Open Finder > Applications > right-click TeamViewer > Move to Trash
3. Remove leftover system files:
\`\`\`
sudo launchctl unload /Library/LaunchDaemons/com.teamviewer.Helper.plist
sudo launchctl unload /Library/LaunchDaemons/com.teamviewer.UninstallerHelper.plist
sudo launchctl unload /Library/LaunchDaemons/com.teamviewer.UninstallerWatcher.plist
sudo rm /Library/LaunchDaemons/com.teamviewer.*
sudo rm /Library/PrivilegedHelperTools/com.teamviewer.Helper
sudo rm -rf /Library/Application\ Support/TeamViewer
rm -rf ~/Library/Application\ Support/TeamViewer
rm -rf ~/Library/Caches/com.teamviewer.*
rm -rf ~/Library/Preferences/com.teamviewer*
rm -rf ~/Library/Logs/TeamViewer
\`\`\`
4. Verify nothing remains:
\`\`\`
ls /Library/LaunchDaemons/com.teamviewer* 2>/dev/null && echo 'STILL PRESENT' || echo 'Clean'
\`\`\`"
            show_fix "Uninstall TeamViewer (run this single block)" \
                "osascript -e 'quit app \"TeamViewer\"' 2>/dev/null; sudo launchctl unload /Library/LaunchDaemons/com.teamviewer.*.plist 2>/dev/null; sudo rm -f /Library/LaunchDaemons/com.teamviewer.* && sudo rm -f /Library/PrivilegedHelperTools/com.teamviewer.Helper && sudo rm -rf '/Library/Application Support/TeamViewer' && sudo rm -rf /Applications/TeamViewer.app && rm -rf ~/Library/Application\\ Support/TeamViewer ~/Library/Caches/com.teamviewer.* ~/Library/Preferences/com.teamviewer* ~/Library/Logs/TeamViewer; echo 'TeamViewer removed.'"
            _record_critical_json "TeamViewer LaunchDaemons are installed" "TeamViewer has persistent system-level daemons running as root."
        else
            medium "Third-party LaunchDaemons found (run as root)" \
"Review these for legitimacy — any of them could be a persistence backdoor:

$DAEMON_LIST

\`\`\`
Fix: Investigate each one. Remove any that are not needed:
     sudo launchctl unload /Library/LaunchDaemons/<plist>
     sudo rm /Library/LaunchDaemons/<plist>
\`\`\`"
            show_fix "Remove unwanted LaunchDaemons (example)" \
                "sudo launchctl unload /Library/LaunchDaemons/<plist-name>" \
                "sudo rm /Library/LaunchDaemons/<plist-name>"
            _record_medium_json "Third-party LaunchDaemons found (run as root)" "Review these for legitimacy."
        fi
    else
        pass "No third-party LaunchDaemons"
    fi

    # ── User LaunchAgents ──
    USER_AGENTS=$(ls ~/Library/LaunchAgents/ 2>/dev/null || true)
    if [[ -n "$USER_AGENTS" ]]; then
        AGENT_COUNT=$(echo "$USER_AGENTS" | wc -l | tr -d ' ')
        AGENT_LIST=$(echo "$USER_AGENTS" | sed 's/^/  - /')

        UNKNOWN_AGENTS=""
        while IFS= read -r agent; do
            [[ -z "$agent" ]] && continue
            if ! is_known_agent "$agent"; then
                UNKNOWN_AGENTS+="  - ${agent}\n"
            fi
        done <<< "$USER_AGENTS"
        UNKNOWN_COUNT=$(echo -e "$UNKNOWN_AGENTS" | grep -c '^ ' || true)

        if (( UNKNOWN_COUNT > 0 )); then
            medium "$UNKNOWN_COUNT unknown user LaunchAgent(s) found (${AGENT_COUNT} total) — review for legitimacy" \
"Unknown agents (not in whitelist):
$(echo -e "$UNKNOWN_AGENTS")
All agents:
$AGENT_LIST

\`\`\`
Fix: Review each one. Remove unneeded agents:
     launchctl unload ~/Library/LaunchAgents/<plist>
     rm ~/Library/LaunchAgents/<plist>
\`\`\`"
            qecho -e "$UNKNOWN_AGENTS"
            show_fix "Remove unwanted LaunchAgents (example)" \
                "launchctl unload ~/Library/LaunchAgents/<plist-name>" \
                "rm ~/Library/LaunchAgents/<plist-name>"
            _record_medium_json "$UNKNOWN_COUNT unknown user LaunchAgent(s) found" "Review for legitimacy."
        else
            pass "$AGENT_COUNT user LaunchAgents (all known/whitelisted)"
        fi
    else
        pass "No user LaunchAgents"
    fi

    # ── Cron jobs ──
    CRON_JOBS=$(crontab -l 2>/dev/null || true)
    if [[ -n "$CRON_JOBS" ]]; then
        medium "Cron jobs found for current user" \
"$CRON_JOBS

\`\`\`
Fix: Review with: crontab -l
     Edit with:   crontab -e
\`\`\`"
        show_fix "Review cron jobs" \
            "crontab -l" \
            "# Edit with: crontab -e"
        _record_medium_json "Cron jobs found for current user" "Review cron jobs for legitimacy."
    else
        pass "No cron jobs"
    fi

    # ── Certificates / mkcert ──
    MKCERT_ROOT=""
    if cmd_exists mkcert; then
        MKCERT_ROOT=$(mkcert -CAROOT 2>/dev/null || true)
    fi
    if [[ -n "$MKCERT_ROOT" && -d "$MKCERT_ROOT" ]]; then
        CA_KEY="$MKCERT_ROOT/rootCA-key.pem"
        if [[ -f "$CA_KEY" ]]; then
            KEY_PERMS=$(stat -f "%Lp" "$CA_KEY" 2>/dev/null || echo "unknown")
            if [[ "$KEY_PERMS" != "600" ]]; then
                high "mkcert root CA key has loose permissions ($KEY_PERMS)" \
"mkcert has installed a local root CA. If the private key is stolen, an attacker can silently MITM all your HTTPS traffic.

CA root: $MKCERT_ROOT
Key permissions: $KEY_PERMS (should be 600)

\`\`\`
Fix: chmod 600 \"$CA_KEY\"
     If not actively using mkcert: mkcert -uninstall
\`\`\`"
                show_fix "Fix mkcert CA key permissions" \
                    "chmod 600 \"$CA_KEY\""
                _record_high_json "mkcert root CA key has loose permissions ($KEY_PERMS)" "mkcert has installed a local root CA."
            else
                pass "mkcert CA key permissions are 600"
            fi
        fi
    else
        pass "No mkcert local CA detected"
    fi
}

check_software_safari() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Safari Safe File Auto-Open"

    local auto_open
    auto_open=$(defaults read com.apple.Safari AutoOpenSafeDownloads 2>/dev/null || echo "unknown")

    if [[ "$auto_open" == "1" ]]; then
        medium "Safari auto-opens 'safe' files after downloading" \
"Safari automatically opens files it considers 'safe' (PDFs, images, archives). Malicious files disguised as safe types can auto-execute.

\`\`\`
Fix: Safari > Settings > General > Uncheck 'Open safe files after downloading'
\`\`\`"
        show_fix "Disable Safari auto-open" \
            "defaults write com.apple.Safari AutoOpenSafeDownloads -bool false"
        _record_medium_json "Safari auto-opens 'safe' files after downloading" "Malicious files disguised as safe types can auto-execute."
    else
        pass "Safari does not auto-open downloaded files"
    fi
}

check_software_secure_keyboard() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Secure Keyboard Entry (Terminal)"

    local ske
    ske=$(defaults read com.apple.Terminal SecureKeyboardEntry 2>/dev/null || echo "unknown")

    if [[ "$ske" == "1" ]]; then
        pass "Secure Keyboard Entry is enabled in Terminal"
    elif [[ "$ske" == "0" ]]; then
        medium "Secure Keyboard Entry is disabled in Terminal" \
"Without Secure Keyboard Entry, other applications can intercept keystrokes typed in Terminal, including passwords and commands.

\`\`\`
Fix: Terminal > Secure Keyboard Entry (menu bar) > Enable
     Or: defaults write com.apple.Terminal SecureKeyboardEntry -bool true
\`\`\`"
        show_fix "Enable Secure Keyboard Entry" \
            "defaults write com.apple.Terminal SecureKeyboardEntry -bool true"
        _record_medium_json "Secure Keyboard Entry is disabled in Terminal" "Other applications can intercept keystrokes typed in Terminal."
    else
        pass "Secure Keyboard Entry: could not determine (may use a different terminal)"
    fi
}

check_software_docker() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Docker Daemons"

    if daemon_loaded com.docker.vmnetd 2>/dev/null || daemon_loaded com.docker.socket 2>/dev/null; then
        medium "Docker system daemons are installed (run as root)" \
"Docker's vmnetd and socket daemon run as root-level LaunchDaemons. Containers can be used for privilege escalation.

\`\`\`
Fix: Only run Docker when actively needed. Consider lighter alternatives like Colima.
\`\`\`"
        show_fix "Consider lighter alternatives" \
            "# Stop Docker Desktop when not in use" \
            "# Consider Colima: brew install colima"
        _record_medium_json "Docker system daemons are installed (run as root)" "Docker daemons run as root-level LaunchDaemons."
    else
        pass "No Docker system daemons detected"
    fi
}

###############################################################################
# MAIN EXECUTION
###############################################################################

# Compute active checks (for progress display)
ACTIVE_CHECKS=$(count_active_checks)
if [[ -n "$CATEGORY_FILTER" ]]; then
    PARTIAL_AUDIT=true
fi

# ── Header ───────────────────────────────────────────────────────────
qecho ""
qprint "${CYAN}╔══════════════════════════════════════════════════════╗${NC}\n"
qprint "${CYAN}║         macOS Security Audit — %s            ║${NC}\n" "$DATE_STAMP"
qprint "${CYAN}╚══════════════════════════════════════════════════════╝${NC}\n"
qecho ""

HW_MODEL=$(sysctl -n hw.model 2>/dev/null || echo "Unknown")
HW_CHIP=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || system_profiler SPHardwareDataType 2>/dev/null | awk -F': ' '/Chip/{print $2}' || echo "Unknown")
OS_VERSION=$(sw_vers -productVersion 2>/dev/null || echo "Unknown")
OS_BUILD=$(sw_vers -buildVersion 2>/dev/null || echo "Unknown")
SERIAL=$(system_profiler SPHardwareDataType 2>/dev/null | awk -F': ' '/Serial Number/{print $2; exit}' || echo "Unknown")

qprint "  Machine : %s (%s)\n" "$HW_MODEL" "$HW_CHIP"
qprint "  macOS   : %s (%s)\n" "$OS_VERSION" "$OS_BUILD"
qprint "  Serial  : %s\n" "$SERIAL"
if $PARTIAL_AUDIT; then
    qprint "  Filter  : %s\n" "$CATEGORY_FILTER"
fi
qecho ""

spin_start "Running security checks…"

# ── Execute all checks ───────────────────────────────────────────────
check_encryption_filevault 1
check_encryption_timemachine 2
check_system_sip 3
check_system_gatekeeper 4
check_system_lockdown 5
check_system_rsr 6
check_system_xprotect 7
check_system_kext 8
check_system_findmymac 9
check_network_firewall 10
check_network_exposure 11
check_network_dns 12
check_network_wifi 13
check_network_internet_sharing 14
check_network_wake 15
check_sharing_services 16
check_sharing_remote_apple_events 17
check_sharing_content_caching 18
check_sharing_printer 19
check_sharing_media 20
check_sharing_handoff 21
check_auth_users 22
check_auth_ssh 23
check_auth_screensaver 24
check_auth_login_window 25
check_auth_touchid 26
check_auth_usb 27
check_privacy_location 28
check_privacy_analytics 29
check_privacy_bluetooth 30
check_privacy_siri 31
check_software_updates 32
check_software_review 33
check_software_safari 34
check_software_secure_keyboard 35
check_software_docker 36

###############################################################################
# TERMINAL SUMMARY
###############################################################################
spin_stop
GRADE=$(letter_grade $SCORE)

if ! $QUIET_MODE; then
    echo ""
    qprint "${CYAN}┌─────────────────────────────────────┐${NC}\n"
    qprint "${CYAN}│       Security Audit Complete        │${NC}\n"
    qprint "${CYAN}├────────────┬────────────────────────┤${NC}\n"
    qprint "${CYAN}│${NC} ${RED}CRITICAL${NC}   ${CYAN}│${NC} %-22s ${CYAN}│${NC}\n" "${#CRITICALS[@]}"
    qprint "${CYAN}│${NC} ${YELLOW}HIGH${NC}       ${CYAN}│${NC} %-22s ${CYAN}│${NC}\n" "${#HIGHS[@]}"
    qprint "${CYAN}│${NC} ${YELLOW}MEDIUM${NC}     ${CYAN}│${NC} %-22s ${CYAN}│${NC}\n" "${#MEDIUMS[@]}"
    qprint "${CYAN}│${NC} ${GREEN}PASS${NC}       ${CYAN}│${NC} %-22s ${CYAN}│${NC}\n" "${#PASSES[@]}"
    qprint "${CYAN}├────────────┼────────────────────────┤${NC}\n"
    qprint "${CYAN}│${NC} Score      ${CYAN}│${NC} %-22s ${CYAN}│${NC}\n" "$SCORE / 100"
    qprint "${CYAN}│${NC} Grade      ${CYAN}│${NC} %-22s ${CYAN}│${NC}\n" "$GRADE"
    qprint "${CYAN}└────────────┴────────────────────────┘${NC}\n"
    if $PARTIAL_AUDIT; then
        qprint "\n  ${YELLOW}Partial audit — categories: %s${NC}\n" "$CATEGORY_FILTER"
    fi
    echo ""
fi

if $QUIET_MODE; then
    echo "$GRADE ($SCORE/100)"
fi

###############################################################################
# GENERATE REPORT
###############################################################################

if $JSON_MODE; then
    # ── JSON report ──────────────────────────────────────────────────
    {
        printf '{\n'
        printf '  "version": "%s",\n' "$VERSION"
        printf '  "timestamp": "%s",\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        printf '  "machine": {\n'
        printf '    "model": "%s",\n' "$(json_escape "$HW_MODEL")"
        printf '    "chip": "%s",\n' "$(json_escape "$HW_CHIP")"
        printf '    "macos_version": "%s",\n' "$(json_escape "$OS_VERSION")"
        printf '    "build": "%s",\n' "$(json_escape "$OS_BUILD")"
        printf '    "serial": "%s"\n' "$(json_escape "$SERIAL")"
        printf '  },\n'
        printf '  "score": %d,\n' "$SCORE"
        printf '  "grade": "%s",\n' "$GRADE"
        printf '  "partial_audit": %s,\n' "$PARTIAL_AUDIT"
        if $PARTIAL_AUDIT; then
            printf '  "categories_checked": "%s",\n' "$(json_escape "$CATEGORY_FILTER")"
        else
            printf '  "categories_checked": "all",\n'
        fi
        printf '  "summary": {\n'
        printf '    "critical": %d,\n' "${#CRITICALS[@]}"
        printf '    "high": %d,\n' "${#HIGHS[@]}"
        printf '    "medium": %d,\n' "${#MEDIUMS[@]}"
        printf '    "pass": %d,\n' "${#PASSES[@]}"
        printf '    "total": %d\n' "$ACTIVE_CHECKS"
        printf '  },\n'
        printf '  "findings": [\n'
        local first=true
        for finding in "${JSON_FINDINGS[@]}"; do
            if $first; then
                first=false
            else
                printf ',\n'
            fi
            printf '    %s' "$finding"
        done
        printf '\n  ]\n'
        printf '}\n'
    } > "$OUTPUT_FILE"
else
    # ── Markdown report ──────────────────────────────────────────────
    {
    cat <<EOF
# macOS Security Audit Report

**Machine:** ${HW_MODEL} (${HW_CHIP})
**macOS:** ${OS_VERSION} (${OS_BUILD})
**Serial:** ${SERIAL}
**Date:** ${DATE_STAMP}
**Overall Grade:** ${GRADE} (${SCORE}/100)
EOF

    if $PARTIAL_AUDIT; then
        printf "\n> **Partial audit** — only categories: %s\n" "$CATEGORY_FILTER"
    fi

    cat <<EOF

---

## PASS — Strong Foundations

| Check | Status |
|---|---|
EOF

    for p in "${PASSES[@]}"; do
        printf "| %s | PASS |\n" "$p"
    done

    if (( ${#CRITICALS[@]} > 0 )); then
        cat <<EOF

---

## CRITICAL — Fix Immediately

EOF
        idx=1
        for c in "${CRITICALS[@]}"; do
            printf "### %d. %s\n\n" "$idx" "$c"
            echo ""
            idx=$((idx + 1))
        done
    fi

    if (( ${#HIGHS[@]} > 0 )); then
        cat <<EOF

---

## HIGH — Fix Soon

EOF
        idx=1
        for h in "${HIGHS[@]}"; do
            printf "### %d. %s\n\n" "$idx" "$h"
            echo ""
            idx=$((idx + 1))
        done
    fi

    if (( ${#MEDIUMS[@]} > 0 )); then
        cat <<EOF

---

## MEDIUM — Recommended Hardening

EOF
        idx=1
        for m in "${MEDIUMS[@]}"; do
            printf "### %d. %s\n\n" "$idx" "$m"
            echo ""
            idx=$((idx + 1))
        done
    fi

    cat <<EOF

---

## Summary

| Severity | Count |
|---|---|
| PASS | ${#PASSES[@]} |
| CRITICAL | ${#CRITICALS[@]} |
| HIGH | ${#HIGHS[@]} |
| MEDIUM | ${#MEDIUMS[@]} |
| **Overall Grade** | **${GRADE}** (${SCORE}/100) |

---

*Generated by [macos-security-audit](https://github.com/fexxdev/macos-security-audit) v${VERSION} on ${DATE_STAMP}*
EOF

    } > "$OUTPUT_FILE"
fi

if ! $QUIET_MODE; then
    if $JSON_MODE; then
        qprint "  ${GREEN}JSON report written to: %s${NC}\n" "$OUTPUT_FILE"
    else
        qprint "  ${GREEN}Report written to: %s${NC}\n" "$OUTPUT_FILE"
    fi
    qprint "  ${CYAN}Review the report:${NC} cat %s\n" "$OUTPUT_FILE"
    echo ""
fi

# ── Exit code based on grade ─────────────────────────────────────────
case "$GRADE" in
    A+|A|A-|B+|B|B-) exit 0 ;;
    C+|C|C-)         exit 1 ;;
    *)               exit 2 ;;
esac
