#!/usr/bin/env bash
#
# macos-security-audit
# Comprehensive macOS security audit script.
# Produces a Markdown (or JSON) report covering disk encryption, firewall, SIP,
# Gatekeeper, network exposure, sharing services, user accounts,
# persistence mechanisms, credentials, and more.
#
# Author:  fexxdev
# License: MIT
# Source:  https://github.com/fexxdev/macos-security-audit
#
# Usage:
#   macos-security-audit                          # run with default output
#   macos-security-audit --output report.md       # custom output path
#   macos-security-audit --show-fix               # show fix commands after each finding
#   macos-security-audit --json                   # output as JSON
#   macos-security-audit --category encryption    # run only encryption checks
#   macos-security-audit --quiet                  # print only the grade
#   macos-security-audit --list-checks            # show all checks
#
# The report is a Markdown file you can read, share, or diff over time.

set -euo pipefail

VERSION="2.0.0"
TOTAL_CHECKS=36

# ── Colours / symbols for terminal output ────────────────────────────
if [[ -t 1 ]]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; NC=''
fi
PASS="${GREEN}PASS${NC}"; FAIL="${RED}FAIL${NC}"; WARN="${YELLOW}WARN${NC}"; INFO="${CYAN}INFO${NC}"

# ── Output modes ─────────────────────────────────────────────────────
JSON_MODE=false
QUIET_MODE=false
CATEGORY_FILTER=""
PARTIAL_AUDIT=false

# ── list_checks ──────────────────────────────────────────────────────
list_checks() {
    printf " %-4s %-14s %s\n" "#" "Category" "Check"
    printf " %-4s %-14s %s\n" "---" "--------------" "------------------------------------"
    printf " %-4s %-14s %s\n" "1"  "encryption" "Disk Encryption (FileVault)"
    printf " %-4s %-14s %s\n" "2"  "encryption" "Time Machine Backup & Encryption"
    printf " %-4s %-14s %s\n" "3"  "system"     "System Integrity Protection (SIP)"
    printf " %-4s %-14s %s\n" "4"  "system"     "Gatekeeper & Secure Boot"
    printf " %-4s %-14s %s\n" "5"  "system"     "Lockdown Mode"
    printf " %-4s %-14s %s\n" "6"  "system"     "Rapid Security Response"
    printf " %-4s %-14s %s\n" "7"  "system"     "XProtect Definitions"
    printf " %-4s %-14s %s\n" "8"  "system"     "Kernel Extensions"
    printf " %-4s %-14s %s\n" "9"  "system"     "Find My Mac"
    printf " %-4s %-14s %s\n" "10" "network"    "Firewall & Stealth Mode"
    printf " %-4s %-14s %s\n" "11" "network"    "Network Exposure"
    printf " %-4s %-14s %s\n" "12" "network"    "DNS & Network"
    printf " %-4s %-14s %s\n" "13" "network"    "Wi-Fi Auto-Join for Open Networks"
    printf " %-4s %-14s %s\n" "14" "network"    "Internet Sharing"
    printf " %-4s %-14s %s\n" "15" "network"    "Wake on Network Access"
    printf " %-4s %-14s %s\n" "16" "sharing"    "Sharing Services"
    printf " %-4s %-14s %s\n" "17" "sharing"    "Remote Apple Events"
    printf " %-4s %-14s %s\n" "18" "sharing"    "Content Caching"
    printf " %-4s %-14s %s\n" "19" "sharing"    "Printer Sharing"
    printf " %-4s %-14s %s\n" "20" "sharing"    "Media Sharing"
    printf " %-4s %-14s %s\n" "21" "sharing"    "Handoff"
    printf " %-4s %-14s %s\n" "22" "auth"       "User Accounts & Authentication"
    printf " %-4s %-14s %s\n" "23" "auth"       "SSH Configuration"
    printf " %-4s %-14s %s\n" "24" "auth"       "Screen Saver Timeout"
    printf " %-4s %-14s %s\n" "25" "auth"       "Login Window Configuration"
    printf " %-4s %-14s %s\n" "26" "auth"       "Touch ID"
    printf " %-4s %-14s %s\n" "27" "auth"       "USB Restricted Mode"
    printf " %-4s %-14s %s\n" "28" "privacy"    "Location Services"
    printf " %-4s %-14s %s\n" "29" "privacy"    "Analytics & Telemetry Sharing"
    printf " %-4s %-14s %s\n" "30" "privacy"    "Bluetooth Discoverability"
    printf " %-4s %-14s %s\n" "31" "privacy"    "Siri Voice Trigger"
    printf " %-4s %-14s %s\n" "32" "software"   "Software Updates"
    printf " %-4s %-14s %s\n" "33" "software"   "Installed Software & Persistence"
    printf " %-4s %-14s %s\n" "34" "software"   "Safari Safe File Auto-Open"
    printf " %-4s %-14s %s\n" "35" "software"   "Secure Keyboard Entry (Terminal)"
    printf " %-4s %-14s %s\n" "36" "software"   "Docker Daemons"
}

# ── Usage ─────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
macos-security-audit v${VERSION}

Comprehensive macOS security audit with Markdown report generation.

USAGE:
    macos-security-audit [OPTIONS]

OPTIONS:
    --help            Show this help message
    --version         Print version and exit
    --output FILE     Custom report path (default: ./security-audit-YYYY-MM-DD.md)
    --show-fix        After each finding, print fix command(s) in a copy-pasteable block
    --json            Output report as JSON instead of Markdown
    --category CAT    Run only checks in given categories (comma-separated)
                      Categories: encryption, system, network, sharing, auth, privacy, software
    --quiet           Suppress terminal output, print only the grade
    --no-color        Disable ANSI color codes in terminal output
    --list-checks     List all checks with category and description

EXAMPLES:
    macos-security-audit
    macos-security-audit --show-fix
    macos-security-audit --json --output report.json
    macos-security-audit --category encryption,network
    macos-security-audit --quiet
    macos-security-audit --list-checks

CHECKS PERFORMED (36):

  Encryption:
     1  Disk Encryption (FileVault)
     2  Time Machine Backup & Encryption

  System:
     3  System Integrity Protection (SIP)
     4  Gatekeeper & Secure Boot
     5  Lockdown Mode
     6  Rapid Security Response
     7  XProtect Definitions
     8  Kernel Extensions
     9  Find My Mac

  Network:
    10  Firewall & Stealth Mode
    11  Network Exposure
    12  DNS & Network
    13  Wi-Fi Auto-Join for Open Networks
    14  Internet Sharing
    15  Wake on Network Access

  Sharing:
    16  Sharing Services
    17  Remote Apple Events
    18  Content Caching
    19  Printer Sharing
    20  Media Sharing
    21  Handoff

  Auth:
    22  User Accounts & Authentication
    23  SSH Configuration
    24  Screen Saver Timeout
    25  Login Window Configuration
    26  Touch ID
    27  USB Restricted Mode

  Privacy:
    28  Location Services
    29  Analytics & Telemetry Sharing
    30  Bluetooth Discoverability
    31  Siri Voice Trigger

  Software:
    32  Software Updates
    33  Installed Software & Persistence
    34  Safari Safe File Auto-Open
    35  Secure Keyboard Entry (Terminal)
    36  Docker Daemons
EOF
    exit 0
}

# ── Parse arguments ──────────────────────────────────────────────────
DATE_STAMP=$(date +%Y-%m-%d)
OUTPUT_FILE=""
SHOW_FIX=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help)       usage ;;
        --version)    echo "macos-security-audit v${VERSION}"; exit 0 ;;
        --output)     OUTPUT_FILE="${2:-}"; shift 2 ;;
        --show-fix)   SHOW_FIX=true; shift ;;
        --json)       JSON_MODE=true; shift ;;
        --quiet)      QUIET_MODE=true; shift ;;
        --no-color)
            RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; NC=''
            PASS="PASS"; FAIL="FAIL"; WARN="WARN"; INFO="INFO"
            shift ;;
        --category)   CATEGORY_FILTER="${2:-}"; shift 2 ;;
        --list-checks) list_checks; exit 0 ;;
        *)
            printf "${RED}Unknown option: %s${NC}\n" "$1"
            printf "Run 'macos-security-audit --help' for usage.\n"
            exit 1
            ;;
    esac
done

# Set default output file based on mode
if [[ -z "$OUTPUT_FILE" ]]; then
    if $JSON_MODE; then
        OUTPUT_FILE="security-audit-${DATE_STAMP}.json"
    else
        OUTPUT_FILE="security-audit-${DATE_STAMP}.md"
    fi
fi

# Show-fix helper: prints a copy-pasteable fix block after a finding.
# Also stores the fix text for JSON output.
LAST_FIX_TEXT=""
show_fix() {
    local description="$1"
    shift
    LAST_FIX_TEXT="$description"
    for cmd in "$@"; do
        LAST_FIX_TEXT="${LAST_FIX_TEXT}\n${cmd}"
    done
    if $SHOW_FIX && ! $QUIET_MODE; then
        echo ""
        printf "  ${BOLD}${YELLOW}FIX:${NC} %s\n" "$description"
        for cmd in "$@"; do
            printf "  ${CYAN}\$${NC} %s\n" "$cmd"
        done
    fi
}

# ── Category filtering ──────────────────────────────────────────────
check_category() {
    case $1 in
        1|2) echo "encryption" ;;
        3|4|5|6|7|8|9) echo "system" ;;
        10|11|12|13|14|15) echo "network" ;;
        16|17|18|19|20|21) echo "sharing" ;;
        22|23|24|25|26|27) echo "auth" ;;
        28|29|30|31) echo "privacy" ;;
        32|33|34|35|36) echo "software" ;;
        *) echo "unknown" ;;
    esac
}

should_run_check() {
    local check_num=$1
    if [[ -z "$CATEGORY_FILTER" ]]; then
        return 0
    fi
    local cat
    cat=$(check_category "$check_num")
    if echo ",$CATEGORY_FILTER," | grep -q ",$cat,"; then
        return 0
    fi
    return 1
}

# Count checks that will actually run
count_active_checks() {
    local count=0
    for i in $(seq 1 "$TOTAL_CHECKS"); do
        if should_run_check "$i"; then
            count=$((count + 1))
        fi
    done
    echo "$count"
}

# ── Quiet-mode aware output ──────────────────────────────────────────
qprint() {
    if ! $QUIET_MODE; then
        printf "$@"
    fi
}

qecho() {
    if ! $QUIET_MODE; then
        echo "$@"
    fi
}

# ── JSON helpers ─────────────────────────────────────────────────────
json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\t'/\\t}"
    s="${s//$'\r'/\\r}"
    printf '%s' "$s"
}

declare -a JSON_FINDINGS=()

add_json_finding() {
    local check_num="$1" category="$2" title="$3" severity="$4" summary="$5" detail="$6" fix="${7:-}"
    local fix_json="null"
    if [[ -n "$fix" ]]; then
        fix_json="\"$(json_escape "$fix")\""
    fi
    JSON_FINDINGS+=("$(printf '{"check_number":%d,"category":"%s","title":"%s","severity":"%s","summary":"%s","detail":"%s","fix":%s}' \
        "$check_num" \
        "$(json_escape "$category")" \
        "$(json_escape "$title")" \
        "$(json_escape "$severity")" \
        "$(json_escape "$summary")" \
        "$(json_escape "$detail")" \
        "$fix_json")")
}

# ── Accumulators for the report ──────────────────────────────────────
declare -a PASSES=()
declare -a CRITICALS=()
declare -a HIGHS=()
declare -a MEDIUMS=()

SCORE=100
CURRENT_CHECK_NUM=0
CURRENT_CHECK_TITLE=""
CURRENT_CHECK_CATEGORY=""
CHECKS_RUN=0

pass() {
    PASSES+=("$1")
    qprint "  ${PASS}  %s\n" "$1"
    if $JSON_MODE; then
        add_json_finding "$CURRENT_CHECK_NUM" "$CURRENT_CHECK_CATEGORY" "$CURRENT_CHECK_TITLE" "pass" "$1" "" ""
    fi
}

critical() {
    CRITICALS+=("$(printf '%s\n\n%s' "$1" "$2")")
    SCORE=$((SCORE - 8))
    qprint "  ${FAIL}  %s\n" "$1"
    LAST_FIX_TEXT=""
}

_record_critical_json() {
    if $JSON_MODE; then
        add_json_finding "$CURRENT_CHECK_NUM" "$CURRENT_CHECK_CATEGORY" "$CURRENT_CHECK_TITLE" "critical" "$1" "$2" "$LAST_FIX_TEXT"
    fi
    LAST_FIX_TEXT=""
}

high() {
    HIGHS+=("$(printf '%s\n\n%s' "$1" "$2")")
    SCORE=$((SCORE - 4))
    qprint "  ${WARN}  %s\n" "$1"
    LAST_FIX_TEXT=""
}

_record_high_json() {
    if $JSON_MODE; then
        add_json_finding "$CURRENT_CHECK_NUM" "$CURRENT_CHECK_CATEGORY" "$CURRENT_CHECK_TITLE" "high" "$1" "$2" "$LAST_FIX_TEXT"
    fi
    LAST_FIX_TEXT=""
}

medium() {
    MEDIUMS+=("$(printf '%s\n\n%s' "$1" "$2")")
    SCORE=$((SCORE - 2))
    qprint "  ${WARN}  %s\n" "$1"
    LAST_FIX_TEXT=""
}

_record_medium_json() {
    if $JSON_MODE; then
        add_json_finding "$CURRENT_CHECK_NUM" "$CURRENT_CHECK_CATEGORY" "$CURRENT_CHECK_TITLE" "medium" "$1" "$2" "$LAST_FIX_TEXT"
    fi
    LAST_FIX_TEXT=""
}

letter_grade() {
    local s=$1
    if   (( s >= 95 )); then echo "A+"
    elif (( s >= 90 )); then echo "A"
    elif (( s >= 85 )); then echo "A-"
    elif (( s >= 80 )); then echo "B+"
    elif (( s >= 75 )); then echo "B"
    elif (( s >= 70 )); then echo "B-"
    elif (( s >= 65 )); then echo "C+"
    elif (( s >= 60 )); then echo "C"
    elif (( s >= 55 )); then echo "C-"
    elif (( s >= 50 )); then echo "D+"
    elif (( s >= 45 )); then echo "D"
    elif (( s >= 40 )); then echo "D-"
    else echo "F"
    fi
}

# ── Helpers ──────────────────────────────────────────────────────────
cmd_exists()  { command -v "$1" &>/dev/null; }
daemon_loaded() { launchctl list "$1" &>/dev/null; }

# ── Spinner ──────────────────────────────────────────────────────────
SPINNER_PID=""
SPINNER_FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")

spin_start() {
    if $QUIET_MODE; then return; fi
    local msg="$1"
    (
        i=0
        while true; do
            printf "\r  ${CYAN}%s${NC} %s  " "${SPINNER_FRAMES[$((i % ${#SPINNER_FRAMES[@]}))]}" "$msg"
            sleep 0.08
            i=$((i + 1))
        done
    ) &
    SPINNER_PID=$!
    trap 'kill $SPINNER_PID 2>/dev/null' EXIT
}

spin_stop() {
    if [[ -n "$SPINNER_PID" ]]; then
        kill "$SPINNER_PID" 2>/dev/null
        wait "$SPINNER_PID" 2>/dev/null || true
        SPINNER_PID=""
        if ! $QUIET_MODE; then
            printf "\r\033[K"
        fi
    fi
}

check_header() {
    local num="$1" title="$2"
    CURRENT_CHECK_NUM=$num
    CURRENT_CHECK_TITLE="$title"
    CURRENT_CHECK_CATEGORY=$(check_category "$num")
    CHECKS_RUN=$((CHECKS_RUN + 1))
    spin_stop
    local pct=$(( CHECKS_RUN * 100 / ACTIVE_CHECKS ))
    qprint "${CYAN}[%s/%s %s%%] %s${NC}\n" "$CHECKS_RUN" "$ACTIVE_CHECKS" "$pct" "$title"
}

# ── Known-good LaunchAgent whitelist ─────────────────────────────────
KNOWN_AGENTS=(
    "com.google.GoogleUpdater.wake.plist"
    "com.google.keystone.agent.plist"
    "com.google.keystone.xpcservice.plist"
    "com.jetbrains.AppCode.BridgeService.plist"
    "com.lwouis.alt-tab-macos.plist"
    "com.privateinternetaccess.vpn.client.plist"
    "com.valvesoftware.steamclean.plist"
    "homebrew.mxcl.nginx.plist"
    "org.keepassxc.KeePassXC.plist"
    "com.github.facebook.watchman.plist"
)

is_known_agent() {
    local name="$1"
    for known in "${KNOWN_AGENTS[@]}"; do
        [[ "$name" == "$known" ]] && return 0
    done
    return 1
}

###############################################################################
# CHECKS — Encryption
###############################################################################

check_encryption_filevault() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Disk Encryption (FileVault)"
    if fdesetup status 2>/dev/null | grep -q "On"; then
        pass "FileVault is ON"
    else
        critical "FileVault is OFF" \
"Your entire disk is readable if the device is lost or stolen.

\`\`\`
Fix: System Settings > Privacy & Security > FileVault > Turn On
\`\`\`"
        show_fix "Enable FileVault" \
            "Open System Settings > Privacy & Security > FileVault > Turn On"
        _record_critical_json "FileVault is OFF" "Your entire disk is readable if the device is lost or stolen."
    fi
}

check_encryption_timemachine() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Time Machine Backup & Encryption"

    local tm_status
    tm_status=$(defaults read /Library/Preferences/com.apple.TimeMachine AutoBackup 2>/dev/null || echo "unknown")
    local tm_dest
    tm_dest=$(tmutil destinationinfo 2>/dev/null || echo "")

    if [[ "$tm_status" == "0" ]]; then
        high "Time Machine backups are disabled" \
"Without backups, data loss from ransomware, hardware failure, or accidental deletion is permanent.

\`\`\`
Fix: System Settings > General > Time Machine > Add Backup Destination
\`\`\`"
        show_fix "Enable Time Machine" \
            "Open System Settings > General > Time Machine > Add Backup Destination"
        _record_high_json "Time Machine backups are disabled" "Without backups, data loss from ransomware, hardware failure, or accidental deletion is permanent."
    elif echo "$tm_dest" | grep -qi "Not Encrypted\|Encryption State.*None"; then
        medium "Time Machine backup destination is not encrypted" \
"An unencrypted backup disk exposes all your data if the backup drive is stolen.

\`\`\`
Fix: System Settings > General > Time Machine > select destination > Encrypt Backup
\`\`\`"
        show_fix "Encrypt Time Machine backup" \
            "Open System Settings > General > Time Machine > select destination > Encrypt Backup"
        _record_medium_json "Time Machine backup destination is not encrypted" "An unencrypted backup disk exposes all your data if the backup drive is stolen."
    elif [[ -n "$tm_dest" ]]; then
        pass "Time Machine is enabled with encrypted backup"
    else
        pass "Time Machine: could not determine backup status"
    fi
}

###############################################################################
# CHECKS — System
###############################################################################

check_system_sip() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "System Integrity Protection (SIP)"
    if csrutil status 2>/dev/null | grep -q "enabled"; then
        pass "SIP is enabled"
    else
        critical "SIP is DISABLED" \
"System Integrity Protection prevents modification of protected system files and code injection into system processes. Without it, rootkits can persist trivially.

\`\`\`
Fix: Boot into Recovery Mode (hold Power on Apple Silicon) > Terminal > csrutil enable
\`\`\`"
        show_fix "Enable SIP (requires Recovery Mode)" \
            "# Boot into Recovery Mode (hold Power on Apple Silicon)" \
            "# Open Terminal from Utilities menu, then run:" \
            "csrutil enable"
        _record_critical_json "SIP is DISABLED" "System Integrity Protection prevents modification of protected system files and code injection into system processes."
    fi
}

check_system_gatekeeper() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Gatekeeper & Secure Boot"
    if spctl --status 2>&1 | grep -q "enabled"; then
        pass "Gatekeeper is enabled"
    else
        critical "Gatekeeper is DISABLED" \
"Unsigned / unnotarised apps can run without any warning.

\`\`\`
Fix: sudo spctl --master-enable
\`\`\`"
        show_fix "Enable Gatekeeper" \
            "sudo spctl --master-enable"
        _record_critical_json "Gatekeeper is DISABLED" "Unsigned / unnotarised apps can run without any warning."
    fi

    SECURE_BOOT=$(system_profiler SPiBridgeDataType 2>/dev/null | awk -F': ' '/Secure Boot/{print $2}')
    if [[ "$SECURE_BOOT" == *"Full"* ]]; then
        pass "Secure Boot: Full Security"
    elif [[ -n "$SECURE_BOOT" ]]; then
        high "Secure Boot: $SECURE_BOOT (not Full Security)" \
"Reduced security allows older or modified kernels to boot.

\`\`\`
Fix: Boot into Recovery > Startup Security Utility > Full Security
\`\`\`"
        show_fix "Set Secure Boot to Full Security" \
            "# Boot into Recovery > Startup Security Utility > Full Security"
        _record_high_json "Secure Boot: $SECURE_BOOT (not Full Security)" "Reduced security allows older or modified kernels to boot."
    fi
}

check_system_lockdown() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Lockdown Mode"
    LDM_ENABLED=false
    if defaults read /Library/Managed\ Preferences/.GlobalPreferences LDMGlobalEnabled 2>/dev/null | grep -q "1"; then
        LDM_ENABLED=true
    fi
    if defaults read .GlobalPreferences LDMGlobalEnabled 2>/dev/null | grep -q "1"; then
        LDM_ENABLED=true
    fi

    if $LDM_ENABLED; then
        pass "Lockdown Mode is enabled"
    else
        critical "Lockdown Mode is OFF" \
"For a threat model that includes nation-state actors, Lockdown Mode is Apple's primary hardening feature. It restricts JIT, message attachments, inbound connections, config profiles, and more.

\`\`\`
Fix: System Settings > Privacy & Security > Lockdown Mode > Turn On
Note: Some functionality will be limited (web fonts, certain message types, etc.)
\`\`\`"
        show_fix "Enable Lockdown Mode" \
            "Open System Settings > Privacy & Security > Lockdown Mode > Turn On"
        _record_critical_json "Lockdown Mode is OFF" "For a threat model that includes nation-state actors, Lockdown Mode is Apple's primary hardening feature."
    fi
}

check_system_rsr() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Rapid Security Response"

    local rsr
    rsr=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate CriticalUpdateInstall 2>/dev/null || echo "unknown")
    local rsr_auto
    rsr_auto=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate AutomaticallyInstallMacOSUpdates 2>/dev/null || echo "unknown")

    if [[ "$rsr" == "0" ]] || [[ "$rsr_auto" == "0" ]]; then
        high "Rapid Security Responses may not install automatically" \
"Apple's Rapid Security Responses patch actively exploited vulnerabilities within hours. Disabling them leaves your system exposed.

\`\`\`
Fix: System Settings > General > Software Update > Automatic Updates > enable 'Install Security Responses and system files'
\`\`\`"
        show_fix "Enable Rapid Security Responses" \
            "sudo defaults write /Library/Preferences/com.apple.SoftwareUpdate CriticalUpdateInstall -bool true"
        _record_high_json "Rapid Security Responses may not install automatically" "Apple's Rapid Security Responses patch actively exploited vulnerabilities within hours."
    else
        pass "Rapid Security Responses are enabled"
    fi
}

check_system_xprotect() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "XProtect Definitions"

    local xp_version=""
    local xp_plist="/Library/Apple/System/Library/CoreServices/XProtect.bundle/Contents/Info.plist"
    if [[ -f "$xp_plist" ]]; then
        xp_version=$(defaults read "$xp_plist" CFBundleShortVersionString 2>/dev/null || echo "")
    fi

    local last_xp_update=""
    last_xp_update=$(system_profiler SPInstallHistoryDataType 2>/dev/null | grep -A2 "XProtect" | awk -F': ' '/Install Date/{print $2; exit}' || echo "")

    if [[ -n "$last_xp_update" ]]; then
        local update_epoch
        update_epoch=$(date -j -f "%m/%d/%y, %I:%M %p" "$last_xp_update" "+%s" 2>/dev/null || \
                       date -j -f "%Y-%m-%d" "$last_xp_update" "+%s" 2>/dev/null || echo "0")
        local now_epoch
        now_epoch=$(date "+%s")
        if [[ "$update_epoch" != "0" ]]; then
            local days_ago=$(( (now_epoch - update_epoch) / 86400 ))
            if (( days_ago > 90 )); then
                medium "XProtect definitions may be stale (last updated ${days_ago} days ago, version: ${xp_version:-unknown})" \
"XProtect is macOS's built-in malware detection. Definitions older than 90 days may miss recent threats.

\`\`\`
Fix: System Settings > General > Software Update > check for updates
\`\`\`"
                show_fix "Update XProtect definitions" \
                    "sudo softwareupdate --background-critical"
                _record_medium_json "XProtect definitions may be stale (${days_ago} days old)" "XProtect is macOS's built-in malware detection. Definitions older than 90 days may miss recent threats."
            else
                pass "XProtect definitions are current (${days_ago} days old, version: ${xp_version:-unknown})"
            fi
        else
            pass "XProtect installed (version: ${xp_version:-unknown}, could not determine age)"
        fi
    elif [[ -n "$xp_version" ]]; then
        pass "XProtect installed (version: ${xp_version})"
    else
        medium "Could not verify XProtect definitions" \
"XProtect should be installed on all Macs. Verify manually.

\`\`\`
Fix: System Settings > General > Software Update > check for updates
\`\`\`"
        _record_medium_json "Could not verify XProtect definitions" "XProtect should be installed on all Macs."
    fi
}

check_system_kext() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Kernel Extensions"

    local extensions
    extensions=$(system_profiler SPExtensionsDataType 2>/dev/null || echo "")
    local third_party=""
    if [[ -n "$extensions" ]]; then
        third_party=$(echo "$extensions" | grep -B1 "Obtained from:.*Not Signed\|Obtained from:.*Identified Developer\|Obtained from:.*Unknown" | grep "Extension Name:" | sed 's/.*Extension Name: /  - /' || true)
    fi

    if [[ -n "$third_party" ]]; then
        medium "Third-party kernel extensions loaded" \
"Kernel extensions run with full system privileges. Third-party kexts increase attack surface:

$third_party

\`\`\`
Fix: Review loaded extensions. macOS is moving to System Extensions — ask vendors for updated drivers.
     System Settings > General > Login Items & Extensions
\`\`\`"
        show_fix "Review kernel extensions" \
            "# System Settings > General > Login Items & Extensions"
        _record_medium_json "Third-party kernel extensions loaded" "Kernel extensions run with full system privileges."
    else
        pass "No third-party kernel extensions detected"
    fi
}

check_system_findmymac() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Find My Mac"

    local fmm
    fmm=$(defaults read com.apple.FindMyMac FMMEnabled 2>/dev/null || echo "unknown")

    if [[ "$fmm" == "1" ]]; then
        pass "Find My Mac is enabled"
    elif [[ "$fmm" == "0" ]]; then
        medium "Find My Mac is disabled" \
"Find My Mac allows you to locate, lock, or erase a lost/stolen Mac remotely.

\`\`\`
Fix: System Settings > Apple ID > iCloud > Find My Mac > Turn On
\`\`\`"
        show_fix "Enable Find My Mac" \
            "Open System Settings > Apple ID > iCloud > Find My Mac > Turn On"
        _record_medium_json "Find My Mac is disabled" "Find My Mac allows you to locate, lock, or erase a lost/stolen Mac remotely."
    else
        pass "Find My Mac: could not determine status (check manually)"
    fi
}

###############################################################################
# CHECKS — Network
###############################################################################

check_network_firewall() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Firewall & Stealth Mode"
    FW_BIN="/usr/libexec/ApplicationFirewall/socketfilterfw"
    if "$FW_BIN" --getglobalstate 2>/dev/null | grep -q "enabled"; then
        pass "Firewall is enabled"
    else
        critical "Firewall is DISABLED" \
"Your Mac accepts inbound connections from the network with no filtering.

\`\`\`
Fix: System Settings > Network > Firewall > Turn On
\`\`\`"
        show_fix "Enable Firewall" \
            "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate on"
        _record_critical_json "Firewall is DISABLED" "Your Mac accepts inbound connections from the network with no filtering."
    fi

    if "$FW_BIN" --getstealthmode 2>/dev/null | grep -qi "on\|enabled"; then
        pass "Stealth Mode is ON"
    else
        high "Stealth Mode is OFF" \
"Your Mac responds to network probes (ping, port scans), making it visible on untrusted networks.

\`\`\`
Fix: System Settings > Network > Firewall > Options > Enable Stealth Mode
\`\`\`"
        show_fix "Enable Stealth Mode" \
            "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setstealthmode on"
        _record_high_json "Stealth Mode is OFF" "Your Mac responds to network probes (ping, port scans), making it visible on untrusted networks."
    fi
}

check_network_exposure() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Network Exposure"

    OPEN_PORTS=$(lsof -iTCP -sTCP:LISTEN -P -n 2>/dev/null | grep -v "127.0.0.1\|::1" | tail -n +2 || true)

    if [[ -n "$OPEN_PORTS" ]]; then
        PORT_LIST=$(echo "$OPEN_PORTS" | awk '{printf "  - %s (PID %s) on %s\n", $1, $2, $9}' | sort -u)
        high "Services listening on all network interfaces" \
"The following services are reachable by anyone on your local network:

$PORT_LIST

\`\`\`
Fix: Bind services to 127.0.0.1 (localhost) or stop them if not needed.
     For nginx: change 'listen 8080' to 'listen 127.0.0.1:8080' in nginx.conf
     To stop nginx: brew services stop nginx
\`\`\`"
        qecho "$PORT_LIST"
        show_fix "Stop exposed services (examples)" \
            "brew services stop nginx" \
            "# Or bind to localhost in service configuration"
        _record_high_json "Services listening on all network interfaces" "Services are reachable by anyone on your local network."
    else
        pass "No services exposed on all interfaces"
    fi

    ICMP_BCAST=$(sysctl -n net.inet.icmp.bmcastecho 2>/dev/null || echo "0")
    if [[ "$ICMP_BCAST" == "1" ]]; then
        high "ICMP broadcast echo is enabled" \
"Your machine responds to broadcast pings, making it trivially discoverable on any network.

\`\`\`
Fix: sudo sysctl -w net.inet.icmp.bmcastecho=0
     Persist: echo 'net.inet.icmp.bmcastecho=0' | sudo tee -a /etc/sysctl.conf
\`\`\`"
        show_fix "Disable ICMP broadcast echo" \
            "sudo sysctl -w net.inet.icmp.bmcastecho=0"
        _record_high_json "ICMP broadcast echo is enabled" "Your machine responds to broadcast pings."
    else
        pass "ICMP broadcast echo disabled"
    fi
}

check_network_dns() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "DNS & Network"

    DNS_SERVERS=$(scutil --dns 2>/dev/null | awk '/nameserver\[0\]/{print $3}' | head -2 | sort -u | tr '\n' ', ' | sed 's/,$//')
    KNOWN_GOOD="1.1.1.1|1.0.0.1|8.8.8.8|8.8.4.4|9.9.9.9|149.112.112.112"
    if echo "$DNS_SERVERS" | grep -qE "$KNOWN_GOOD"; then
        pass "DNS servers: $DNS_SERVERS (known privacy-respecting providers)"
    elif [[ -n "$DNS_SERVERS" ]]; then
        medium "DNS servers: $DNS_SERVERS — not a well-known privacy DNS" \
"Consider using encrypted DNS (1.1.1.1, 9.9.9.9, 8.8.8.8) to prevent DNS snooping.

\`\`\`
Fix: System Settings > Network > Wi-Fi > Details > DNS > add 1.1.1.1 and 1.0.0.1
     Better: use a DNS-over-HTTPS client or configure it in your router
\`\`\`"
        show_fix "Set DNS to privacy-respecting providers" \
            "networksetup -setdnsservers Wi-Fi 1.1.1.1 1.0.0.1"
        _record_medium_json "DNS servers: $DNS_SERVERS" "Consider using encrypted DNS to prevent DNS snooping."
    else
        medium "Could not determine DNS servers" \
"Verify DNS configuration manually."
        _record_medium_json "Could not determine DNS servers" "Verify DNS configuration manually."
    fi

    HOSTS_EXTERNAL=$(grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' /etc/hosts 2>/dev/null | grep -v '127.0.0.1\|255.255.255.255\|0.0.0.0' || true)
    if [[ -n "$HOSTS_EXTERNAL" ]]; then
        HOST_LIST=$(echo "$HOSTS_EXTERNAL" | sed 's/^/  /')
        high "External/production IPs found in /etc/hosts" \
"Your /etc/hosts contains non-local IP addresses. Anyone with access to your machine can see your infrastructure layout:

$HOST_LIST

\`\`\`
Fix: Remove production IPs from /etc/hosts. Use a VPN + private DNS instead.
\`\`\`"
        show_fix "Edit /etc/hosts to remove external IPs" \
            "sudo nano /etc/hosts"
        _record_high_json "External/production IPs found in /etc/hosts" "Your /etc/hosts contains non-local IP addresses."
    else
        pass "No external IPs in /etc/hosts"
    fi

    VPN_CONNS=$(scutil --nc list 2>/dev/null | grep -v "^Available\|^$" || true)
    VPN_PROCS=$(ps aux 2>/dev/null | grep -iE "openvpn|wireguard|privateinternet|pia|viscosity|mullvad|nordvpn" | grep -v grep || true)
    if [[ -n "$VPN_PROCS" ]]; then
        pass "VPN process detected as running"
    elif [[ -n "$VPN_CONNS" ]]; then
        medium "VPN configurations exist but no VPN appears to be running" \
"You have VPN software installed but it's not currently active.

\`\`\`
Fix: Enable your VPN, especially on untrusted networks.
     Consider always-on VPN configuration.
\`\`\`"
        show_fix "Enable your VPN" \
            "# Start your VPN client or connect via:" \
            "scutil --nc start 'VPN Connection Name'"
        _record_medium_json "VPN configurations exist but no VPN appears to be running" "You have VPN software installed but it's not currently active."
    else
        medium "No VPN detected" \
"No VPN connections or processes found. Use a VPN on untrusted networks.

\`\`\`
Fix: Install and configure a trusted VPN provider.
\`\`\`"
        _record_medium_json "No VPN detected" "No VPN connections or processes found."
    fi
}

check_network_wifi() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Wi-Fi Auto-Join for Open Networks"

    ASK_TO_JOIN=$(defaults read /Library/Preferences/SystemConfiguration/com.apple.airport.preferences JoinModeFallback 2>/dev/null || \
        defaults read com.apple.airport.preferences JoinModeFallback 2>/dev/null || echo "unknown")

    if [[ "$ASK_TO_JOIN" == "JoinOpen" ]]; then
        high "Wi-Fi is set to auto-join open networks" \
"Your Mac will automatically connect to any open (unencrypted) Wi-Fi network. This makes evil twin and MITM attacks trivial.

\`\`\`
Fix: System Settings > Wi-Fi > Ask to Join Networks > 'Ask'
     Also: disable 'Auto-Join Hotspot' or set to 'Ask to Join'
\`\`\`"
        show_fix "Disable auto-join for open networks" \
            "# System Settings > Wi-Fi > Ask to Join Networks > 'Ask'" \
            "sudo defaults write /Library/Preferences/SystemConfiguration/com.apple.airport.preferences JoinModeFallback -string 'Prompt'"
        _record_high_json "Wi-Fi is set to auto-join open networks" "Your Mac will automatically connect to any open Wi-Fi network."
    else
        pass "Wi-Fi auto-join for open networks: not enabled (or set to Ask)"
    fi
}

check_network_internet_sharing() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Internet Sharing"

    local nat_enabled
    nat_enabled=$(defaults read /Library/Preferences/SystemConfiguration/com.apple.nat NAT 2>/dev/null | grep -c "Enabled = 1" || true)

    if [[ "$nat_enabled" -gt 0 ]]; then
        high "Internet Sharing is enabled" \
"Your Mac is acting as a network router, sharing its internet connection. This creates an unmanaged access point.

\`\`\`
Fix: System Settings > General > Sharing > Internet Sharing > Turn Off
\`\`\`"
        show_fix "Disable Internet Sharing" \
            "Open System Settings > General > Sharing > Internet Sharing > Turn Off"
        _record_high_json "Internet Sharing is enabled" "Your Mac is acting as a network router."
    else
        pass "Internet Sharing is disabled"
    fi
}

check_network_wake() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Wake on Network Access"

    local womp
    womp=$(pmset -g 2>/dev/null | awk '/womp/{print $2}' || echo "unknown")
    if [[ "$womp" == "unknown" ]] || [[ -z "$womp" ]]; then
        womp=$(systemsetup -getwakeonnetworkaccess 2>/dev/null | awk -F': ' '{print $2}' || echo "unknown")
    fi

    if [[ "$womp" == "1" ]] || echo "$womp" | grep -qi "on"; then
        medium "Wake on Network Access is enabled" \
"Your Mac can be woken remotely via network traffic, increasing the window for remote attacks when you expect it to be asleep.

\`\`\`
Fix: System Settings > Battery > Options > Wake for network access > Never
     Or: sudo pmset -a womp 0
\`\`\`"
        show_fix "Disable Wake on Network Access" \
            "sudo pmset -a womp 0"
        _record_medium_json "Wake on Network Access is enabled" "Your Mac can be woken remotely via network traffic."
    else
        pass "Wake on Network Access is disabled"
    fi
}

###############################################################################
# CHECKS — Sharing
###############################################################################

check_sharing_services() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Sharing Services"

    # AirDrop
    AIRDROP_MODE=$(defaults read com.apple.sharingd DiscoverableMode 2>/dev/null || echo "unknown")
    if [[ "$AIRDROP_MODE" == "Everyone" ]]; then
        critical "AirDrop is set to 'Everyone'" \
"Your Mac is discoverable by any nearby device. Proximity-based attacks and surveillance have used AirDrop as a vector.

\`\`\`
Fix: System Settings > General > AirDrop & Handoff > AirDrop > 'Contacts Only' or 'No One'
\`\`\`"
        show_fix "Set AirDrop to Contacts Only" \
            "defaults write com.apple.sharingd DiscoverableMode -string 'Contacts Only'"
        _record_critical_json "AirDrop is set to 'Everyone'" "Your Mac is discoverable by any nearby device."
    elif [[ "$AIRDROP_MODE" == "Off" ]]; then
        pass "AirDrop is OFF"
    else
        pass "AirDrop is set to '${AIRDROP_MODE}'"
    fi

    # Screen Sharing
    if daemon_loaded com.apple.screensharing; then
        high "Screen Sharing is enabled" \
"Allows remote VNC-like access to your desktop.

\`\`\`
Fix: System Settings > General > Sharing > Disable 'Screen Sharing'
\`\`\`"
        show_fix "Disable Screen Sharing" \
            "sudo launchctl unload -w /System/Library/LaunchDaemons/com.apple.screensharing.plist"
        _record_high_json "Screen Sharing is enabled" "Allows remote VNC-like access to your desktop."
    else
        pass "Screen Sharing is disabled"
    fi

    # File Sharing (SMB)
    if daemon_loaded com.apple.smbd; then
        high "File Sharing (SMB) is enabled" \
"Exposes file shares on the network.

\`\`\`
Fix: System Settings > General > Sharing > Disable 'File Sharing'
\`\`\`"
        show_fix "Disable File Sharing" \
            "sudo launchctl unload -w /System/Library/LaunchDaemons/com.apple.smbd.plist"
        _record_high_json "File Sharing (SMB) is enabled" "Exposes file shares on the network."
    else
        pass "File Sharing (SMB) is disabled"
    fi

    # Remote Management (ARD)
    # daemon_loaded alone is insufficient — the agent stays registered in launchd
    # even after kickstart -deactivate. Check if it's actually running (has a PID)
    # or if the preference plist indicates it's active.
    if launchctl list com.apple.RemoteDesktop.agent 2>/dev/null | grep -q '"PID"'; then
        critical "Remote Management (ARD) is loaded" \
"Apple Remote Desktop agent is running. This allows remote control of your machine if exploited or misconfigured.

\`\`\`
Fix: System Settings > General > Sharing > Disable 'Remote Management'
     Or via terminal: sudo /System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart -deactivate -configure -access -off
\`\`\`"
        show_fix "Disable Remote Management (ARD)" \
            "sudo /System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart -deactivate -configure -access -off"
        _record_critical_json "Remote Management (ARD) is loaded" "Apple Remote Desktop agent is running."
    else
        pass "Remote Management (ARD) is disabled"
    fi

    # SSH / Remote Login
    SSH_STATUS=$(systemsetup -getremotelogin 2>/dev/null || echo "")
    if echo "$SSH_STATUS" | grep -qi "on"; then
        high "Remote Login (SSH) is enabled" \
"SSH access is available. Ensure it's intentional and key-only auth is configured.

\`\`\`
Fix: System Settings > General > Sharing > Disable 'Remote Login'
     Or harden: PasswordAuthentication no in /etc/ssh/sshd_config
\`\`\`"
        show_fix "Disable Remote Login" \
            "sudo systemsetup -setremotelogin off"
        _record_high_json "Remote Login (SSH) is enabled" "SSH access is available."
    else
        pass "Remote Login (SSH) is disabled"
    fi
}

check_sharing_remote_apple_events() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Remote Apple Events"

    local rae
    rae=$(systemsetup -getremoteappleevents 2>/dev/null || echo "")
    if [[ -z "$rae" ]]; then
        if launchctl list com.apple.AEServer &>/dev/null; then
            rae="On"
        else
            rae="Off"
        fi
    fi

    if echo "$rae" | grep -qi "on"; then
        high "Remote Apple Events are enabled" \
"Remote Apple Events allow other computers to send AppleScript commands to this Mac. This is a remote code execution vector.

\`\`\`
Fix: System Settings > General > Sharing > Remote Apple Events > Turn Off
\`\`\`"
        show_fix "Disable Remote Apple Events" \
            "sudo systemsetup -setremoteappleevents off"
        _record_high_json "Remote Apple Events are enabled" "Remote Apple Events allow other computers to send AppleScript commands to this Mac."
    else
        pass "Remote Apple Events are disabled"
    fi
}

check_sharing_content_caching() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Content Caching"

    local cc
    cc=$(defaults read /Library/Preferences/com.apple.AssetCache.plist Activated 2>/dev/null || echo "0")

    if [[ "$cc" == "1" ]]; then
        medium "Content Caching is enabled" \
"Content Caching shares downloaded Apple content with other devices on your network. While useful in managed environments, it increases network exposure.

\`\`\`
Fix: System Settings > General > Sharing > Content Caching > Turn Off
\`\`\`"
        show_fix "Disable Content Caching" \
            "Open System Settings > General > Sharing > Content Caching > Turn Off"
        _record_medium_json "Content Caching is enabled" "Content Caching shares downloaded Apple content with other devices on your network."
    else
        pass "Content Caching is disabled"
    fi
}

check_sharing_printer() {
    local n=$1
    if ! should_run_check "$n"; then return; fi
    check_header "$n" "Printer Sharing"

    local ps
